<div class="page" id="page-pdv">
  <div class="pdv-layout">
    <div class="pdv-products">
      <div class="flex gap-12 mb-16" style="flex-wrap:wrap">
        <div class="search-bar" style="flex:1;min-width:160px">
          <span>🔍</span>
          <input type="text" placeholder="Buscar produto..." id="pdvSearch" autocomplete="off" oninput="filterPDV(this.value)">
        </div>
        <div class="search-bar pdv-barcode-wrap" style="flex:0 1 260px;min-width:200px">
          <span>📷</span>
          <input type="text" id="pdvBarcodeInput" autocomplete="off" spellcheck="false" inputmode="text" placeholder="Código de barras / SKU…" aria-label="Leitor de código de barras">
        </div>
        <div class="filter-bar">
          <button class="filter-btn active" onclick="setPDVFilter('todos',this)">Todos</button>
          <button class="filter-btn" onclick="setPDVFilter('cell',this)">📱</button>
          <button class="filter-btn" onclick="setPDVFilter('laptop',this)">💻</button>
          <button class="filter-btn" onclick="setPDVFilter('pc',this)">🖥️</button>
          <button class="filter-btn" onclick="setPDVFilter('others',this)">📦</button>
        </div>
      </div>
      <div class="pdv-products-grid" id="pdvGrid"></div>
    </div>

    <div class="cart-panel">
      <div class="cart-header">
        <div class="cart-title">🛒 Carrinho</div>
        <div class="text-xs text-muted mt-4" id="cartCount">0 itens</div>
      </div>
      <div class="cart-items" id="cartItems">
        <div class="empty-state" id="cartEmpty">
          <div class="empty-icon">🛍️</div>
          <p>Nenhum item adicionado</p>
        </div>
      </div>
      <div class="cart-footer">
        <div class="cart-totals">
          <div class="cart-total-row"><span>Subtotal</span><span class="val mono" id="cartSubtotal">R$ 0,00</span></div>
          <div class="cart-total-row"><span>Desconto</span><span class="val mono text-green" id="cartDiscount">- R$ 0,00</span></div>
          <div class="cart-total-row"><span>Acréscimo</span><span class="val mono text-red" id="cartExtra">+ R$ 0,00</span></div>
          <div class="divider"></div>
          <div class="cart-total-row grand"><span>Total</span><span class="val" id="cartTotal">R$ 0,00</span></div>
        </div>
        <div class="payment-methods" id="paymentMethodsButtons"></div>
        <div class="cart-adjust-actions">
          <button class="btn btn-ghost btn-sm" type="button" id="btnOpenDiscountModal">Desconto</button>
          <button class="btn btn-ghost btn-sm" type="button" id="btnOpenExtraModal">Acréscimo</button>
        </div>
        <button class="btn btn-primary w-full" style="justify-content:center;" onclick="finalizarVenda()">✅ Finalizar Venda</button>
        <button class="btn btn-ghost btn-sm w-full" style="justify-content:center;" onclick="clearCart()">🗑️ Limpar</button>
      </div>
    </div>
  </div>
</div>

<div class="pdv-modal-overlay" id="cartAdjustmentModal">
  <div class="pdv-modal-card pdv-adjustment-card">
    <div class="pdv-modal-header">
      <div class="pdv-modal-title" id="cartAdjustmentTitle">Ajustar valor</div>
      <button class="pdv-modal-close" id="closeCartAdjustmentModalBtn">✕</button>
    </div>
    <div class="pdv-modal-body">
      <p class="text-sm text-muted" id="cartAdjustmentHint">Escolha o tipo e o valor.</p>
      <div class="adjustment-type-group">
        <label class="adjustment-type-option">
          <input type="radio" name="adjustmentType" value="fixed" checked>
          <span>Valor fixo (R$)</span>
        </label>
        <label class="adjustment-type-option">
          <input type="radio" name="adjustmentType" value="percent">
          <span>Porcentagem (%)</span>
        </label>
      </div>
      <div class="adjustment-quick-values" id="cartAdjustmentQuickValues"></div>
      <input class="form-input" id="cartAdjustmentValue" type="number" min="0" step="0.01" placeholder="0,00">
    </div>
    <div class="pdv-modal-footer">
      <button class="btn btn-ghost btn-sm" id="cancelCartAdjustmentBtn">Cancelar</button>
      <button class="btn btn-primary btn-sm" id="saveCartAdjustmentBtn">Salvar</button>
    </div>
  </div>
</div>

<div class="pdv-modal-overlay" id="confirmActionModal">
  <div class="pdv-modal-card">
    <div class="pdv-modal-header">
      <div class="pdv-modal-title" id="confirmActionTitle">Confirmar ação</div>
      <button class="pdv-modal-close" id="closeConfirmActionModalBtn">✕</button>
    </div>
    <div class="pdv-modal-body">
      <p class="text-sm text-muted" id="confirmActionMessage">Deseja continuar?</p>
      <div class="pdv-confirm-summary" id="confirmActionSummary">
        <div class="pdv-confirm-totals" id="confirmActionTotals"></div>
        <div id="pdvCashPaymentSection" class="pdv-cash-section" hidden>
          <label class="pdv-cash-label" for="pdvCashReceivedInput">Valor recebido (R$) <span class="text-muted" style="font-weight:500;">— opcional</span></label>
          <input class="form-input" type="number" id="pdvCashReceivedInput" min="0" step="0.01" inputmode="decimal" autocomplete="off" placeholder="Vazio = pagou o valor exato" aria-describedby="pdvCashPaymentHint">
          <div class="pdv-cash-change-row">
            <span>Troco</span>
            <strong class="mono" id="pdvCashChangeDisplay">R$ 0,00</strong>
          </div>
          <p class="text-xs text-muted" id="pdvCashPaymentHint">Só preencha se o cliente der um valor maior que o total (para calcular o troco). Se pagar em cédulas/moedas exatas, deixe em branco.</p>
        </div>
        <div class="pdv-confirm-items-wrap">
          <div class="text-xs text-muted">Itens da compra</div>
          <div class="pdv-confirm-items" id="confirmActionItems"></div>
        </div>
      </div>
    </div>
    <div class="pdv-modal-footer">
      <button class="btn btn-ghost btn-sm" id="cancelConfirmActionBtn">Cancelar</button>
      <button class="btn btn-primary btn-sm" id="confirmActionBtn">Confirmar</button>
    </div>
  </div>
</div>

<div class="pdv-modal-overlay" id="paymentWaitingModal">
  <div class="pdv-modal-card">
    <div class="pdv-modal-header">
      <div class="pdv-modal-title" id="paymentWaitingTitle">Aguardando pagamento</div>
      <button class="pdv-modal-close" id="closePaymentWaitingModalBtn">✕</button>
    </div>
    <div class="pdv-modal-body">
      <div class="pdv-payment-waiting-top">
        <div class="pdv-payment-loader" aria-hidden="true"></div>
        <div class="pdv-payment-status-wrap">
          <p class="text-sm text-muted" id="paymentWaitingMessage">Finalize o pagamento na maquininha.</p>
          <div class="pdv-payment-status-chip" id="paymentWaitingStatusChip">Iniciando cobrança...</div>
        </div>
      </div>
      <div id="paymentWaitingQrWrap" class="pdv-payment-qr-wrap" style="display:none;">
        <div id="paymentWaitingQrLoader" class="pdv-payment-qr-loader">
          <div class="pdv-payment-loader" aria-hidden="true"></div>
          <div class="text-xs text-muted">Gerando QR Code PIX...</div>
        </div>
        <img id="paymentWaitingQrImage" alt="QR Code PIX" class="pdv-payment-qr-image" />
      </div>
      <div id="paymentWaitingQrTextWrap" style="display:none;">
        <label class="text-xs text-muted" for="paymentWaitingQrText">Código PIX (copia e cola)</label>
        <textarea id="paymentWaitingQrText" class="form-input" rows="3" readonly></textarea>
        <button class="btn btn-ghost btn-sm mt-8" type="button" id="copyPixCodeBtn">Copiar código PIX</button>
      </div>
      <div class="text-xs text-muted mt-8" id="paymentWaitingHint">Não feche esta tela até o pagamento ser concluído.</div>
    </div>
    <div class="pdv-modal-footer">
      <button class="btn btn-ghost btn-sm" id="cancelPaymentWaitingBtn">Cancelar pagamento</button>
    </div>
  </div>
</div>

<div class="pdv-modal-overlay" id="paymentResultModal">
  <div class="pdv-modal-card pdv-payment-result-card">
    <div class="pdv-modal-header">
      <div class="pdv-modal-title" id="paymentResultTitle">Resultado do pagamento</div>
      <button class="pdv-modal-close" id="closePaymentResultModalBtn">✕</button>
    </div>
    <div class="pdv-modal-body">
      <p class="text-sm text-muted" id="paymentResultMessage"></p>
      <div class="pdv-result-list" id="paymentResultDetails"></div>
    </div>
    <div class="pdv-modal-footer">
      <button class="btn btn-primary btn-sm" id="paymentResultOkBtn">Entendi</button>
    </div>
  </div>
</div>