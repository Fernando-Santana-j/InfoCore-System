<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('reusable/head') %>
  <title>Login | InfoCore System</title>
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <main class="login-page">
    <div class="login-bg-orb login-bg-orb--left" aria-hidden="true"></div>
    <div class="login-bg-orb login-bg-orb--right" aria-hidden="true"></div>

    <section class="login-card-wrap">
      <form class="login-card"  id="loginForm" autocomplete="on">
        <div class="login-card-top">
          <div class="brand-badge">InfoCore System</div>
          <h1 class="brand-title">Bem-vindo de volta</h1>
          <p class="brand-text">Entre com seu acesso para continuar gerenciando sua operação.</p>
        </div>

    

        <div class="form-group">
          <label class="form-label" for="email">E-mail</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="voce@empresa.com" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Senha</label>
          <div class="password-wrap">
            <input class="form-input" type="password" id="password" name="pass" placeholder="Digite sua senha" required minlength="6">
            <button class="password-toggle" type="button" id="togglePassword" aria-label="Mostrar ou ocultar senha">👁️</button>
          </div>
        </div>

        <div class="login-row">
          <label class="remember-me">
            <input type="checkbox" id="remember">
            <span>Lembrar acesso</span>
          </label>
          <a class="forgot-link" href="#">Esqueci a senha</a>
        </div>

        <button class="btn btn-primary w-full login-submit" type="submit" id="loginSubmit">
          Entrar
        </button>

        <p class="login-footer">
          Ambiente seguro e criptografado.
        </p>
      </form>
    </section>
  </main>

  <script src="/js/login.js"></script>
</body>
</html>
