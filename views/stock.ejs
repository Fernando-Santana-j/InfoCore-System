<% 
  const _cfg = (typeof appData !== 'undefined' && appData && appData.configs && !appData.configs.error) ? appData.configs : {};
  const _catObj = (_cfg && _cfg.category && typeof _cfg.category === 'object') ? _cfg.category : null;
  let stockCategoryEntries;
  if (_catObj && Object.keys(_catObj).length) {
    stockCategoryEntries = Object.keys(_catObj).map((k) => [k, _catObj[k] || {}]).sort((a, b) => {
      const na = String(a[1].name != null ? a[1].name : a[0]);
      const nb = String(b[1].name != null ? b[1].name : b[0]);
      return na.localeCompare(nb, 'pt-BR');
    });
  } else {
    stockCategoryEntries = [['others', { name: 'Outros', color: 'var(--text2)' }]];
  }
%>
<div class="page" id="page-estoque">
  <div class="flex flex-between flex-wrap gap-12 mb-16">
    <div class="search-bar" style="flex:1;max-width:380px;">
      <span>🔍</span>
      <input type="text" placeholder="Pesquisar produto, SKU, categoria..." id="stockSearch" oninput="filterStock(this.value)">
    </div>
    <div class="filter-bar">
      <button class="filter-btn active" onclick="setStockFilter('todos',this)">Todos</button>
      <button class="filter-btn" onclick="setStockFilter('baixo',this)">⚠️ Crítico</button>
      <button class="filter-btn" onclick="setStockFilter('normal',this)">✅ Normal</button>
      <button class="filter-btn" onclick="setStockFilter('alto',this)">📦 Abundante</button>
    </div>
    <button class="btn btn-primary" onclick="openStockAddProductModal()">✨ Novo Produto</button>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">Controle de Estoque</div>
        <div class="card-subtitle" id="stockCount">Carregando...</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="exportData('estoque')">📥 Exportar</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>SKU</th>
            <th>Produto</th>
            <th>Categoria</th>
            <th>Qtd. Atual</th>
            <th>Mín.</th>
            <th>Preço Custo</th>
            <th>Preço Venda</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="stockTable"></tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-addProduct">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">+ Adicionar Produto</div>
      <button class="modal-close" onclick="closeModal('addProduct')">✕</button>
    </div>
    <div class="form-grid">
      <div class="form-group form-full">
        <label class="form-label">SKU</label>
        <div class="form-readonly-hint mono" id="newSkuHint">Será gerado automaticamente ao salvar: código numérico de 8 dígitos (único por produto, adequado para código de barras).</div>
      </div>
      <div class="form-group">
        <label class="form-label">Nome do Produto</label>
        <input class="form-input" id="newName" placeholder="Ex: Coca-Cola 2L">
      </div>
      <div class="form-group">
        <label class="form-label">Categoria</label>
        <select class="form-select" id="newCategory">
          <% stockCategoryEntries.forEach(function (entry) { var key = entry[0], meta = entry[1] || {}; %>
          <option value="<%= key %>"><%= meta.name != null ? meta.name : key %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group form-full">
        <label class="form-label">Foto do produto</label>
        <input type="file" id="newProductImage" class="form-input" accept="image/jpeg,image/png,image/gif,image/webp">
        <div class="stock-img-preview-wrap" id="newImagePreviewWrap">
          <img id="newImagePreview" class="stock-img-preview is-empty" alt="Pré-visualização">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Preço de Custo (R$)</label>
        <input class="form-input mono input-money" id="newCost" type="text" inputmode="numeric" autocomplete="off" placeholder="0,00">
      </div>
      <div class="form-group">
        <label class="form-label">Preço de Venda (R$)</label>
        <input class="form-input mono input-money" id="newPrice" type="text" inputmode="numeric" autocomplete="off" placeholder="0,00">
      </div>
      <div class="form-group">
        <label class="form-label">Quantidade Inicial</label>
        <input class="form-input mono" id="newQty" type="number" placeholder="0">
      </div>
      <div class="form-group">
        <label class="form-label">Estoque Mínimo</label>
        <input class="form-input mono" id="newMin" type="number" placeholder="10">
      </div>
      <div class="form-group form-full">
        <label class="form-label">Descrição</label>
        <textarea class="form-textarea" id="newDesc" placeholder="Descrição do produto..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('addProduct')">Cancelar</button>
      <button class="btn btn-primary" onclick="addProduct()">✅ Adicionar Produto</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-editProduct">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">✏️ Editar Produto</div>
      <button class="modal-close" onclick="closeModal('editProduct')">✕</button>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">SKU</label>
        <input class="form-input mono" id="editSku" readonly style="opacity:0.5">
      </div>
      <div class="form-group">
        <label class="form-label">Nome do Produto</label>
        <input class="form-input" id="editName">
      </div>
      <div class="form-group">
        <label class="form-label">Categoria</label>
        <select class="form-select" id="editCategory">
          <% stockCategoryEntries.forEach(function (entry) { var key = entry[0], meta = entry[1] || {}; %>
          <option value="<%= key %>"><%= meta.name != null ? meta.name : key %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group form-full">
        <label class="form-label">Foto do produto</label>
        <input type="file" id="editProductImage" class="form-input" accept="image/jpeg,image/png,image/gif,image/webp">
        <div class="stock-img-preview-wrap">
          <img id="editImagePreview" class="stock-img-preview is-empty" alt="Foto atual">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Preço Custo (R$)</label>
        <input class="form-input mono input-money" id="editCost" type="text" inputmode="numeric" autocomplete="off">
      </div>
      <div class="form-group">
        <label class="form-label">Preço Venda (R$)</label>
        <input class="form-input mono input-money" id="editPrice" type="text" inputmode="numeric" autocomplete="off">
      </div>
      <div class="form-group">
        <label class="form-label">Qtd. Atual</label>
        <input class="form-input mono" id="editQty" type="number">
      </div>
      <div class="form-group">
        <label class="form-label">Estoque Mínimo</label>
        <input class="form-input mono" id="editMin" type="number">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-danger" onclick="deleteProductModal()">🗑️ Excluir</button>
      <button class="btn btn-ghost" onclick="closeModal('editProduct')">Cancelar</button>
      <button class="btn btn-primary" onclick="saveEditProduct()">💾 Salvar Alterações</button>
    </div>
  </div>
</div>

