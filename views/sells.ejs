<div class="page" id="page-vendas">
  <div class="flex flex-wrap gap-12 mb-16">
    <div class="search-bar" style="flex:1;max-width:360px">
      <span>🔍</span>
      <input type="text" placeholder="Pesquisar codigo, venda, cliente..." id="salesSearch" oninput="filterSales(this.value)">
    </div>
    <div class="filter-bar">
      <button class="filter-btn active" onclick="setSalesFilter('todos',this)">Todos</button>
      <button class="filter-btn" onclick="setSalesFilter('hoje',this)">Hoje</button>
      <button class="filter-btn" onclick="setSalesFilter('semana',this)">Esta semana</button>
    </div>
    <button class="btn btn-ghost btn-sm" onclick="exportData('vendas')">📥 Exportar</button>
  </div>

  <div class="grid-3 gap-14 mb-16">
    <div class="card">
      <div class="stat-icon" style="background:rgba(240,192,64,0.15);color:var(--gold);margin-bottom:8px;">💰</div>
      <div class="mono font-extrabold" style="font-size:1.4rem;" id="saleTotal">R$ 0,00</div>
      <div class="text-xs text-muted mt-4">Total do período</div>
    </div>
    <div class="card">
      <div class="stat-icon" style="background:rgba(61,220,132,0.15);color:var(--green);margin-bottom:8px;">🧾</div>
      <div class="font-extrabold" style="font-size:1.4rem;" id="saleCount">0</div>
      <div class="text-xs text-muted mt-4">Vendas realizadas</div>
    </div>
    <div class="card">
      <div class="stat-icon" style="background:rgba(74,158,255,0.15);color:var(--blue);margin-bottom:8px;">📊</div>
      <div class="mono font-extrabold" style="font-size:1.4rem;" id="saleAvg">R$ 0,00</div>
      <div class="text-xs text-muted mt-4">Ticket médio</div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Histórico de Vendas</div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Codigo</th>
            <th>Data/Hora</th>
            <th>Cliente</th>
            <th>Itens</th>
            <th>Desconto</th>
            <th>Total</th>
            <th>Pagamento</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="salesTable"></tbody>
      </table>
    </div>
  </div>

  <div class="modal-overlay" id="modal-saleDetail">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Detalhes da Venda #<span id="saleDetailId">0</span></div>
        <button class="modal-close" onclick="closeModal('saleDetail')">✕</button>
      </div>
      <div style="padding:0 20px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
          <div>
            <div style="font-size:0.75rem;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Cliente</div>
            <div id="saleDetailClient" style="font-weight:600;color:var(--text);">-</div>
          </div>
          <div>
            <div style="font-size:0.75rem;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Data/Hora</div>
            <div id="saleDetailDate" class="mono" style="color:var(--text);">-</div>
          </div>
        </div>
        <div style="background:var(--bg2);border-radius:8px;padding:12px;margin-bottom:16px;">
          <table style="width:100%;font-size:0.9rem;">
            <thead style="background:var(--bg3);border-radius:4px;overflow:hidden;">
              <tr>
                <th style="text-align:left;padding:8px;font-size:0.75rem;color:var(--text2);text-transform:uppercase;">Produto</th>
                <th style="text-align:right;padding:8px;font-size:0.75rem;color:var(--text2);text-transform:uppercase;">Qtd</th>
                <th style="text-align:right;padding:8px;font-size:0.75rem;color:var(--text2);text-transform:uppercase;">Preço</th>
                <th style="text-align:right;padding:8px;font-size:0.75rem;color:var(--text2);text-transform:uppercase;">Subtotal</th>
              </tr>
            </thead>
            <tbody id="saleDetailItems"></tbody>
          </table>
        </div>
        <div style="display:grid;grid-template-columns:auto 1fr;gap:12px;row-gap:8px;text-align:right;">
          <div style="text-align:right;color:var(--text2);">Subtotal:</div>
          <div class="mono" id="saleDetailSubtotal">R$ 0,00</div>
          <div style="text-align:right;color:var(--text2);">Desconto:</div>
          <div class="mono" id="saleDetailDiscount">R$ 0,00</div>
          <div style="text-align:right;font-weight:600;border-top:1px solid var(--bg2);padding-top:8px;">Total:</div>
          <div class="mono" style="font-weight:600;font-size:1.1rem;border-top:1px solid var(--bg2);padding-top:8px;" id="saleDetailTotal">R$ 0,00</div>
        </div>
        <div style="margin-top:16px;padding:16px;background:var(--bg2);border-radius:8px;">
          <div style="font-size:0.75rem;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Método de Pagamento</div>
          <div id="saleDetailPayment" style="font-weight:600;">-</div>
          <div id="saleDetailCashWrap" style="display:none;margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:0.9rem;">
            <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="color:var(--text2);">Valor recebido</span><span class="mono" id="saleDetailCashReceived">—</span></div>
            <div style="display:flex;justify-content:space-between;"><span style="color:var(--text2);">Troco</span><span class="mono" style="font-weight:700;color:var(--gold);" id="saleDetailCashChange">—</span></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('saleDetail')">Fechar</button>
        <button class="btn btn-ghost btn-sm" onclick="printSale(document.getElementById('saleDetailId').textContent)">🖨️ Imprimir</button>
      </div>
    </div>
  </div>
</div>